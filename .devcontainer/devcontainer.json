{
  "name": "local-agent-harness",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22-bookworm",
  "features": {
    // We deliberately do NOT install docker-outside-of-docker here. The
    // container only consumes DMR over HTTP at model-runner.docker.internal,
    // and the standalone `docker model` CLI plugin conflicts with Docker
    // Desktop's DMR (both want port 12434). Model management is a host-side
    // concern: use the Docker Desktop UI or run `docker model pull ai/...`
    // in a HOST shell.
    "ghcr.io/devcontainers/features/copilot-cli:latest": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  // Environment for every shell and the Copilot CLI process. Copilot CLI is
  // configured purely via env vars. DMR ignores Authorization, so the API key
  // value is irrelevant but Copilot CLI requires the variable to be set.
  //
  // IMPORTANT: from inside a Docker Desktop container, DMR is reachable at
  // http://model-runner.docker.internal (port 80, not 12434). The host-side
  // URL http://localhost:12434/engines/v1 does NOT work from inside the
  // container — `localhost` there means the container itself. Docker Desktop
  // automatically intercepts the model-runner.docker.internal hostname for
  // every container when DMR is enabled, so no extra --add-host is needed
  // (and adding one would override Docker Desktop's interception and break
  // the connection).
  "containerEnv": {
    "COPILOT_PROVIDER_BASE_URL": "http://model-runner.docker.internal/engines/v1",
    "COPILOT_PROVIDER_TYPE": "openai",
    "COPILOT_MODEL": "ai/gpt-oss",
    "COPILOT_PROVIDER_API_KEY": "not-needed",
    "COPILOT_OFFLINE": "true"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "node"
}